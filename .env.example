# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-06-01

# App
APP_ENV=development
LOG_LEVEL=INFO
SCF_DATA_PATH=data/scf_sample.csv

# FRED (Federal Reserve Economic Data) — free API key at fred.stlouisfed.org
# Enables live inflation rate, Treasury yield, and Fed Funds rate tools in the agent.
# Leave empty to run without FRED tools (agent degrades gracefully).
FRED_API_KEY=
