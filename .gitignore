# Large data and model files — generated locally, not committed
# Leading / anchors to repo root so src/wealthpath/data/ and frontend/src/data/ are unaffected
# data/* (not data/) required so !exceptions below are honoured by git
/data/*
!/data/.gitkeep
!/data/scf_sample.csv

